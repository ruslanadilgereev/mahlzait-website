---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import TrainingsplanPage from "@modules/trainingsplan";

const seo = {
  title: "Trainingsplan erstellen mit KI – Kostenloser Fitness Plan Generator | Mahlzait",
  description:
    "Erstelle deinen individuellen Trainingsplan kostenlos mit KI. Gym, Home oder Bodyweight. Anfänger bis Profi. Mit Übungen, Sätzen, Wiederholungen & Progressionsplan. In Sekunden generiert.",
};

const authorPersonSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.mahlzait.de/#person-ruslan",
  name: "Ruslan Adilgereev",
  url: "https://www.mahlzait.de/team",
  jobTitle: "Founder & Developer",
  worksFor: {
    "@type": "Organization",
    name: "Mahlzait",
    url: "https://www.mahlzait.de",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Ist der Trainingsplan Generator kostenlos?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja, komplett kostenlos. Bis zu 3 Pläne pro Stunde ohne Anmeldung oder Abo.",
      },
    },
    {
      "@type": "Question",
      name: "Welches Erfahrungslevel soll ich wählen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Anfänger: Weniger als 6 Monate regelmäßiges Training. Fortgeschritten: 6 Monate bis 2 Jahre. Profi: Über 2 Jahre mit solider Technik in Grundübungen.",
      },
    },
    {
      "@type": "Question",
      name: "Was bedeutet Split-Typ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der Split bestimmt, wie Muskelgruppen über die Woche verteilt werden. Ganzkörper = alle Muskeln pro Session. Push/Pull/Legs = aufgeteilt nach Drück-, Zug- und Beinübungen. Upper/Lower = Ober- und Unterkörper abwechselnd.",
      },
    },
    {
      "@type": "Question",
      name: "Kann ich nur mit Bodyweight trainieren?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja! Wähle 'Bodyweight' als Equipment und die KI erstellt einen Plan nur mit Eigengewichtsübungen wie Liegestütze, Klimmzüge, Dips und Kniebeugen.",
      },
    },
    {
      "@type": "Question",
      name: "Wie oft sollte ich den Plan wechseln?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Alle 4-6 Wochen. Dein Körper gewöhnt sich an den Trainingsreiz, daher ist regelmäßige Variation wichtig.",
      },
    },
    {
      "@type": "Question",
      name: "Berücksichtigt der Plan Aufwärmen und Cool-Down?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja, jeder Trainingstag enthält ein spezifisches Warm-Up und Cool-Down. Das Aufwärmen ist auf die Übungen des Tages abgestimmt.",
      },
    },
    {
      "@type": "Question",
      name: "Kann ich auch einen Essensplan dazu erstellen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja! In Schritt 3 kannst du einen Essensplan zusätzlich aktivieren. Die Makros werden automatisch auf dein Trainingsziel abgestimmt.",
      },
    },
    {
      "@type": "Question",
      name: "Wie viele Tage pro Woche sind optimal?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Anfänger: 3x pro Woche. Fortgeschrittene: 4-5x. Profis: 5-6x. Mehr ist nicht automatisch besser — Regeneration ist entscheidend für Muskelwachstum.",
      },
    },
    {
      "@type": "Question",
      name: "Werden meine Daten gespeichert?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein, keine Daten werden gespeichert. Der Plan existiert nur in deinem Browser bis du die Seite verlässt.",
      },
    },
    {
      "@type": "Question",
      name: "Was mache ich an Ruhetagen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ruhetage sind für Regeneration. Leichte Aktivität wie Spazierengehen, Stretching oder Yoga ist ideal. Schweres Training an Ruhetagen verhindert optimale Erholung.",
      },
    },
  ],
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Trainingsplan erstellen mit KI",
  description:
    "So erstellst du in wenigen Sekunden deinen individuellen Trainingsplan mit unserem kostenlosen KI-Generator.",
  totalTime: "PT1M",
  tool: { "@type": "HowToTool", name: "Mahlzait Trainingsplan Generator" },
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Basisdaten eingeben",
      text: "Gib dein Geschlecht, Alter, Größe, Gewicht, Ziel und Aktivitätslevel an.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Trainings-Präferenzen wählen",
      text: "Wähle dein Erfahrungslevel, Equipment, Trainingsfrequenz und Zeitbudget pro Session.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Plan generieren lassen",
      text: "Klicke auf 'Plan generieren'. Die KI erstellt einen Wochenplan mit Übungen, Sätzen, Wiederholungen und Pausen.",
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Plan umsetzen und Ernährung tracken",
      text: "Drucke deinen Plan aus und tracke deine Ernährung mit der Mahlzait App für optimale Ergebnisse.",
    },
  ],
};

const homeConfig = {
  ...defaultTemplateConfig,
  privacyPolicy: { seo: defaultTemplateConfig.privacyPolicy.seo, content: "" },
  cookiesPolicy: { seo: defaultTemplateConfig.cookiesPolicy.seo, content: "" },
  termsAndConditions: { seo: defaultTemplateConfig.termsAndConditions.seo, content: "" },
};
---

<Layout {...defaultTemplateConfig} seo={seo}>
  <StructuredData config={defaultTemplateConfig} type="page" pageTitle="Trainingsplan erstellen mit KI" pageDescription={seo.description} />
  <script type="application/ld+json" set:html={JSON.stringify(authorPersonSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <TrainingsplanPage client:load config={homeConfig} />
</Layout>
