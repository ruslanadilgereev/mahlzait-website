---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import EssensplanPage from "@modules/essensplan";

const seo = {
  title: "Essensplan erstellen mit KI – Kostenloser Ernährungsplan Generator | Mahlzait",
  description:
    "Erstelle deinen persönlichen 7-Tage-Essensplan kostenlos mit KI. Kalorienbedarf berechnen, Makros aufteilen, Rezepte generieren. Für Abnehmen, Muskelaufbau & Gewicht halten. Omnivor, vegetarisch oder vegan.",
};

const authorPersonSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.mahlzait.de/#person-ruslan",
  name: "Ruslan Adilgereev",
  url: "https://www.mahlzait.de/team",
  jobTitle: "Founder & Developer",
  worksFor: {
    "@type": "Organization",
    name: "Mahlzait",
    url: "https://www.mahlzait.de",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Ist der Essensplan Generator wirklich kostenlos?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja, du kannst bis zu 3 Pläne pro Stunde komplett kostenlos erstellen. Es gibt keine versteckten Kosten oder Abo-Pflicht.",
      },
    },
    {
      "@type": "Question",
      name: "Wie genau sind die Kalorien- und Makro-Angaben?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Der Kalorienbedarf wird mit der wissenschaftlich validierten Mifflin-St Jeor Formel berechnet, die bei ~70% der Personen auf ±10% genau ist. Die Makros der einzelnen Gerichte sind Richtwerte.",
      },
    },
    {
      "@type": "Question",
      name: "Berücksichtigt der Plan meine Allergien?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja, du kannst Laktose, Gluten, Nüsse, Soja, Ei und Fructose als Unverträglichkeiten angeben. Die KI erstellt dann nur Rezepte ohne diese Zutaten.",
      },
    },
    {
      "@type": "Question",
      name: "Welche Ernährungsformen werden unterstützt?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Aktuell: Omnivor (alles), Vegetarisch und Vegan. Spezielle Diäten wie Keto, Paleo oder Low-FODMAP sind derzeit nicht als eigene Optionen verfügbar.",
      },
    },
    {
      "@type": "Question",
      name: "Kann ich auch einen Trainingsplan dazu erstellen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja! In Schritt 3 kannst du zusätzlich einen Trainingsplan aktivieren. Alternativ nutze unseren Trainingsplan Generator unter /trainingsplan-erstellen/ für noch mehr Optionen.",
      },
    },
    {
      "@type": "Question",
      name: "Wie lange dauert die Generierung?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "In der Regel 5-15 Sekunden. Du siehst den Fortschritt live — jeder Tag wird angezeigt, sobald er fertig ist.",
      },
    },
    {
      "@type": "Question",
      name: "Werden meine Daten gespeichert?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nein. Deine eingegebenen Daten werden nur für die Generierung verwendet und danach nicht gespeichert. Der generierte Plan existiert nur in deinem Browser.",
      },
    },
    {
      "@type": "Question",
      name: "Was unterscheidet diesen Generator von anderen?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Unser Generator berechnet zuerst deinen exakten Kalorienbedarf und Makros wissenschaftlich mit der Mifflin-St Jeor Formel, und gibt diese Werte dann an die KI weiter. So stimmen die Nährwerte — statt dass die KI Kalorien schätzt.",
      },
    },
    {
      "@type": "Question",
      name: "Für wen ist der Essensplan geeignet?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Für alle, die ihre Ernährung strukturieren möchten — ob zum Abnehmen, Muskelaufbau oder für eine ausgewogene Ernährung. Der Generator ist nicht als medizinische Ernährungsberatung gedacht.",
      },
    },
    {
      "@type": "Question",
      name: "Kann ich den Plan ausdrucken?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja, nach der Generierung gibt es einen 'Plan drucken' Button, der eine druckfreundliche Version erstellt.",
      },
    },
  ],
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Essensplan erstellen mit KI",
  description:
    "So erstellst du in wenigen Sekunden deinen persönlichen Ernährungsplan mit unserem kostenlosen KI-Generator.",
  totalTime: "PT1M",
  tool: { "@type": "HowToTool", name: "Mahlzait Essensplan Generator" },
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Basisdaten eingeben",
      text: "Gib dein Geschlecht, Alter, Größe, Gewicht, Ziel und Aktivitätslevel an. Daraus wird dein Kalorienbedarf berechnet.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Ernährungspräferenzen wählen",
      text: "Wähle deine Ernährungsform (omnivor, vegetarisch oder vegan), gib Allergien an und lege Mahlzeitenanzahl und Kochzeit fest.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Plan generieren lassen",
      text: "Klicke auf 'Plan generieren' und warte 5-15 Sekunden. Die KI erstellt einen 7-Tage-Essensplan mit Rezepten und Makros.",
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Plan umsetzen und tracken",
      text: "Drucke deinen Plan aus oder tracke ihn direkt mit der Mahlzait App für iOS und Android.",
    },
  ],
};

const homeConfig = {
  ...defaultTemplateConfig,
  privacyPolicy: { seo: defaultTemplateConfig.privacyPolicy.seo, content: "" },
  cookiesPolicy: { seo: defaultTemplateConfig.cookiesPolicy.seo, content: "" },
  termsAndConditions: { seo: defaultTemplateConfig.termsAndConditions.seo, content: "" },
};
---

<Layout {...defaultTemplateConfig} seo={seo}>
  <StructuredData config={defaultTemplateConfig} type="page" pageTitle="Essensplan erstellen mit KI" pageDescription={seo.description} />
  <script type="application/ld+json" set:html={JSON.stringify(authorPersonSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <EssensplanPage client:load config={homeConfig} />
</Layout>
