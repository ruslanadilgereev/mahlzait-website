---
import Layout from "Layout.astro";
import FoodListTable from "@components/FoodListTable.astro";
import defaultTemplateConfig from "utils/config";
import { foodsByCarbsAsc } from "utils/foodData";

const seo = {
  title: "Low Carb Lebensmittel: Liste mit wenig Kohlenhydraten | Mahlzait",
  description:
    "Low-Carb-Lebensmittel & kohlenhydratarme Lebensmittel – nach Kohlenhydraten pro 100g sortiert. Was du bei Low Carb essen kannst, auf einen Blick.",
};
const siteUrl = "https://www.mahlzait.de";
const foods = foodsByCarbsAsc().slice(0, 120);

const faq = [
  {
    question: "Welche Lebensmittel sind Low Carb?",
    answer:
      "Fleisch, Fisch, Eier, Käse, Tofu und die meisten Gemüsesorten (Blattsalat, Gurke, Zucchini, Brokkoli) enthalten kaum Kohlenhydrate. Auch Nüsse und Avocado sind low carb.",
  },
  {
    question: "Wie viele Kohlenhydrate sind bei Low Carb erlaubt?",
    answer:
      "Es gibt keine feste Grenze. Moderates Low Carb liegt oft bei 50–130 g Kohlenhydraten pro Tag, strenge Varianten (ketogen) unter 50 g. Entscheidend bleibt für das Gewicht die Gesamtkalorienbilanz.",
  },
  {
    question: "Macht Low Carb schneller schlank?",
    answer:
      "Kurzfristig verliert man durch entleerte Glykogenspeicher mehr Wasser. Langfristig zeigen Meta-Analysen aber keinen Vorteil gegenüber anderen Diäten bei gleichem Kaloriendefizit – Low Carb ist eine von mehreren funktionierenden Strategien.",
  },
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Startseite", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Low Carb Lebensmittel", item: `${siteUrl}/low-carb-lebensmittel/` },
  ],
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({ "@type": "Question", name: f.question, acceptedAnswer: { "@type": "Answer", text: f.answer } })),
};
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Low Carb Lebensmittel",
  numberOfItems: foods.length,
  itemListElement: foods.map((food, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${food.name} – ${Math.round(food.overview.carbs_per_100g * 10) / 10} g Kohlenhydrate/100g`,
    url: `${siteUrl}/kalorien/${food.slug}/`,
  })),
};
---

<Layout {...defaultTemplateConfig} seo={seo}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <main class="max-w-screen-lg mx-auto px-4 py-8 md:py-12">
    <nav class="text-sm opacity-60 mb-4" aria-label="Breadcrumb">
      <a href="/" class="hover:underline">Start</a> ›
      <a href="/kalorientabelle/" class="hover:underline">Kalorientabelle</a> › Low Carb Lebensmittel
    </nav>

    <header class="mb-6">
      <h1 class="text-3xl md:text-4xl font-extrabold leading-tight">
        Low Carb Lebensmittel: die Liste mit wenig Kohlenhydraten
      </h1>
      <p class="mt-4 text-lg opacity-80">
        Diese {foods.length} Lebensmittel enthalten besonders wenig
        Kohlenhydrate – sortiert nach Kohlenhydraten pro 100&nbsp;g. Ideal, wenn
        du dich kohlenhydratarm oder ketogen ernähren möchtest.
      </p>
    </header>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/kalorientabelle/" class="btn btn-sm btn-outline">📋 Komplette Kalorientabelle</a>
      <a href="/eiweissreiche-lebensmittel/" class="btn btn-sm btn-outline">💪 Eiweißreiche Lebensmittel</a>
      <a href="/makros-berechnen/" class="btn btn-sm btn-primary">Makros berechnen</a>
    </div>

    <FoodListTable foods={foods} highlight="calories" />

    <section class="mt-12 prose max-w-none">
      <h2>Häufige Fragen</h2>
      {faq.map((f) => (
        <div class="mb-4">
          <h3 class="text-lg font-semibold">{f.question}</h3>
          <p class="opacity-80">{f.answer}</p>
        </div>
      ))}
    </section>

    <section class="mt-10 rounded-2xl bg-base-200 p-6 text-center">
      <h2 class="text-xl font-bold mb-2">Kohlenhydrate im Blick behalten</h2>
      <p class="opacity-80 mb-4">Mit Mahlzait trackst du Kohlenhydrate, Eiweiß und Fett automatisch per Foto.</p>
      <a href={defaultTemplateConfig.appStoreLink} class="btn btn-primary">App laden</a>
    </section>
  </main>
</Layout>
