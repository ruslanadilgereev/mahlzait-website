---
import Layout from "Layout.astro";
import defaultTemplateConfig from "utils/config";
import ArticlePage from "@modules/wissen/article";
import {
  getAllSlugs,
  getArticleMeta,
  getArticleContent,
  getRelatedArticles,
  type ArticleMeta,
} from "@content/wissen";
import {
  getCalculatorsForTags,
  getCalculatorsBySlugs,
} from "utils/topicClusters";

export async function getStaticPaths() {
  const slugs = getAllSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const article = getArticleMeta(slug as string);

if (!article) {
  return Astro.redirect("/wissen/", 301);
}

const content = await getArticleContent(slug as string);

if (!content) {
  return Astro.redirect("/wissen/", 301);
}

// Related articles by shared tags
const relatedArticles = getRelatedArticles(slug as string, 4);

// Related calculators: manual override (article.relatedCalculators) > tag-based matching
const relatedCalculators = article.relatedCalculators?.length
  ? getCalculatorsBySlugs(article.relatedCalculators)
  : getCalculatorsForTags(article.tags, 3);

// Related foods - find food mentions in article content and map to food data
const foodFiles = import.meta.glob("../../data/foods/*.json", { eager: true });
const allFoods = Object.values(foodFiles).map((mod: any) => mod.default || mod);

// Food mapping: common words in articles -> food slugs
const foodKeywordMap: Record<string, string> = {
  "hähnchenbrust": "haehnchenbrust", "hühnerbrust": "haehnchenbrust", "hähnchen": "haehnchenbrust",
  "magerquark": "magerquark", "quark": "quark",
  "haferflocken": "haferflocken", "oats": "haferflocken",
  "reis": "reis", "vollkornreis": "reis",
  "nudeln": "nudeln", "pasta": "nudeln", "spaghetti": "nudeln",
  "brot": "brot", "vollkornbrot": "brot",
  "pizza": "pizza",
  "lachs": "lachsfilet", "lachsfilet": "lachsfilet",
  "avocado": "avocado",
  "banane": "banane",
  "brokkoli": "brokkoli",
  "kartoffel": "kartoffeln", "kartoffeln": "kartoffeln",
  "schokolade": "schokolade",
  "chips": "chips",
  "ei": "ei", "eier": "ei",
  "tofu": "tofu",
  "burger": "burger",
  "schnitzel": "schnitzel",
  "döner": "doener-box",
  "cola": "cola",
  "bier": "bier",
  "wein": "wein",
  "kaffee": "kaffee",
  "cappuccino": "cappuccino",
  "milch": "milch",
  "joghurt": "joghurt",
  "spinat": "spinat",
  "mandeln": "mandeln",
};

const contentLower = content.toLowerCase();
const matchedSlugs = new Set<string>();
for (const [keyword, foodSlug] of Object.entries(foodKeywordMap)) {
  if (contentLower.includes(keyword)) {
    matchedSlugs.add(foodSlug);
  }
}

const relatedFoods = Array.from(matchedSlugs)
  .map((slug) => allFoods.find((f: any) => f.slug === slug))
  .filter(Boolean)
  .slice(0, 8)
  .map((f: any) => ({
    slug: f.slug,
    name: f.name,
    emoji: f.emoji,
    calories_per_100g: f.overview.calories_per_100g,
  }));

const seo = {
  title: `${article.title} | Mahlzait Wissen`,
  description: article.description,
};

const siteUrl = "https://www.mahlzait.de";
const articleUrl = `${siteUrl}/wissen/${article.slug}/`;

// JSON-LD Schemas
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Wissen",
      item: `${siteUrl}/wissen`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: article.title,
      item: articleUrl,
    },
  ],
};

const authorSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#person-ruslan`,
  name: "Ruslan Adilgereev",
  url: `${siteUrl}/team`,
  jobTitle: "Founder",
  worksFor: {
    "@type": "Organization",
    name: "Mahlzait",
    url: siteUrl,
  },
  sameAs: [
    "https://www.linkedin.com/in/ruslanadilgereev",
  ],
};

const reviewedByNode = article.reviewer
  ? {
      "@type": "Person",
      name: article.reviewer.name,
      jobTitle: article.reviewer.credentials,
      hasCredential: {
        "@type": "EducationalOccupationalCredential",
        credentialCategory: article.reviewer.credentials,
      },
      ...(article.reviewer.url ? { url: article.reviewer.url } : {}),
    }
  : undefined;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": ["Article", "MedicalWebPage"],
  headline: article.title,
  description: article.kernaussage ?? article.description,
  ...(article.kernaussage ? { abstract: article.kernaussage } : {}),
  datePublished: article.publishedAt,
  dateModified: article.updatedAt || article.publishedAt,
  inLanguage: "de-DE",
  about: {
    "@type": "MedicalCondition",
    name: "Ernährung und Gewichtsmanagement",
  },
  specialty: {
    "@type": "MedicalSpecialty",
    name: "Diet and Nutrition",
  },
  audience: {
    "@type": "PeopleAudience",
    audienceType: "Erwachsene, die ihre Ernährung verbessern möchten",
  },
  medicalAudience: {
    "@type": "MedicalAudience",
    audienceType: "Patient",
  },
  author: {
    "@type": "Person",
    "@id": `${siteUrl}/#person-ruslan`,
    name: "Ruslan Adilgereev",
    url: `${siteUrl}/team`,
  },
  ...(reviewedByNode
    ? {
        reviewedBy: reviewedByNode,
        lastReviewed: article.reviewer!.reviewedAt,
      }
    : {}),
  publisher: {
    "@type": "Organization",
    name: "Mahlzait",
    url: siteUrl,
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/logo.png`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl,
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["aside[aria-label='Kernaussage']", "h1", ".article-lead"],
  },
  mentions: [
    { "@type": "MobileApplication", "@id": `${siteUrl}#mobileapp` },
    { "@type": "SoftwareApplication", "@id": `${siteUrl}#softwareapp` },
    { "@type": "Organization", "@id": `${siteUrl}#organization` },
  ],
  editorialPolicy: `${siteUrl}/redaktionelle-standards/`,
  keywords: article.tags.join(", "),
  citation: article.sources.map((s) => ({
    "@type": "ScholarlyArticle",
    name: s.title,
    author: s.authors,
    datePublished: s.year.toString(),
    isPartOf: {
      "@type": "Periodical",
      name: s.journal,
    },
    sameAs: s.doi ? `https://doi.org/${s.doi}` : undefined,
  })),
};

const faqSchema = article.faqs && article.faqs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: article.faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    }
  : null;
---

<Layout {...defaultTemplateConfig} seo={seo}>
  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Author (Person) Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(authorSchema)} />

  <!-- Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- FAQ Schema (optional) -->
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <ArticlePage
    client:visible
    config={defaultTemplateConfig}
    article={article}
    content={content}
    relatedArticles={relatedArticles}
    relatedFoods={relatedFoods}
    relatedCalculators={relatedCalculators}
  />
</Layout>

