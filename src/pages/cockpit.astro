---
export const prerender = false;
import Layout from "Layout.astro";
const seo = { title: "Cockpit", description: "" };
---

<Layout {seo} templateConfig={{ theme: "mahlzait", forceTheme: true, backgroundGrid: false, logo: "/logo.png" }}>
  <div id="app" class="min-h-screen bg-gray-950 text-white p-4 md:p-8">
    <!-- Login -->
    <div id="login" class="max-w-sm mx-auto mt-20">
      <h1 class="text-2xl font-bold mb-4 text-center">🔒 Cockpit</h1>
      <input id="pw" type="password" placeholder="Passwort" 
        class="w-full p-3 rounded-lg bg-gray-800 border border-gray-700 text-white mb-3" />
      <button id="loginBtn" 
        class="w-full p-3 rounded-lg bg-emerald-600 hover:bg-emerald-500 font-semibold transition-colors">
        Einloggen
      </button>
      <p id="error" class="text-red-400 text-sm mt-2 hidden">Falsches Passwort</p>
    </div>

    <!-- Dashboard (hidden initially) -->
    <div id="dashboard" class="hidden max-w-6xl mx-auto">
      <div class="flex justify-between items-center mb-8">
        <h1 class="text-3xl font-bold">📊 Mahlzait Cockpit</h1>
        <div class="text-sm text-gray-400">
          <span id="lastUpdate"></span>
          <button id="refreshBtn" class="ml-3 px-3 py-1 bg-gray-800 rounded hover:bg-gray-700">↻</button>
        </div>
      </div>

      <!-- KPIs -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-gray-800 rounded-xl p-5">
          <div class="text-gray-400 text-sm">Zahlende Abos (Apple)</div>
          <div id="kpi-paid" class="text-3xl font-bold text-emerald-400 mt-1">-</div>
        </div>
        <div class="bg-gray-800 rounded-xl p-5">
          <div class="text-gray-400 text-sm">Free Trials</div>
          <div id="kpi-trial" class="text-3xl font-bold text-blue-400 mt-1">-</div>
        </div>
        <div class="bg-gray-800 rounded-xl p-5">
          <div class="text-gray-400 text-sm">MRR Brutto (Apple)</div>
          <div id="kpi-mrr" class="text-3xl font-bold text-yellow-400 mt-1">-</div>
        </div>
        <div class="bg-gray-800 rounded-xl p-5">
          <div class="text-gray-400 text-sm">MRR Netto (Apple)</div>
          <div id="kpi-mrr-net" class="text-3xl font-bold text-green-400 mt-1">-</div>
        </div>
      </div>

      <!-- Plan Split -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <div class="bg-gray-800 rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-3">📱 Plan-Verteilung (Paid)</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span>Monthly (€4,99)</span>
              <span id="split-monthly" class="font-mono text-emerald-400">-</span>
            </div>
            <div class="flex justify-between">
              <span>Yearly (€29,99)</span>
              <span id="split-yearly" class="font-mono text-emerald-400">-</span>
            </div>
          </div>
        </div>
        <div class="bg-gray-800 rounded-xl p-5">
          <h3 class="text-lg font-semibold mb-3">🧪 Trial-Verteilung</h3>
          <div class="space-y-2">
            <div class="flex justify-between">
              <span>Monthly Trial</span>
              <span id="trial-monthly" class="font-mono text-blue-400">-</span>
            </div>
            <div class="flex justify-between">
              <span>Yearly Trial</span>
              <span id="trial-yearly" class="font-mono text-blue-400">-</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Trend -->
      <div class="bg-gray-800 rounded-xl p-5 mb-8">
        <h3 class="text-lg font-semibold mb-3">📈 7-Tage Trend (Apple Paid)</h3>
        <div id="trend" class="flex items-end gap-2 h-40"></div>
        <div id="trend-labels" class="flex gap-2 mt-2 text-xs text-gray-500"></div>
      </div>

      <!-- Raw Data -->
      <details class="bg-gray-800 rounded-xl p-5">
        <summary class="cursor-pointer font-semibold">🔧 Raw Data</summary>
        <pre id="raw" class="mt-3 text-xs text-gray-400 overflow-auto max-h-96"></pre>
      </details>
    </div>
  </div>

  <script is:inline>
    const $ = (s) => document.getElementById(s);

    let password = '';

    $('loginBtn').onclick = () => login();
    $('pw').onkeydown = (e) => { if (e.key === 'Enter') login(); };
    $('refreshBtn').onclick = () => loadData();

    // Check saved password
    const saved = localStorage.getItem('cockpit_pw');
    if (saved) {
      password = saved;
      loadData();
    }

    function login() {
      password = $('pw').value;
      if (!password) return;
      loadData();
    }

    async function loadData() {
      try {
        const res = await fetch(`/api/dashboard?pw=${encodeURIComponent(password)}`);
        if (res.status === 401) {
          $('error').classList.remove('hidden');
          localStorage.removeItem('cockpit_pw');
          return;
        }
        const data = await res.json();
        if (data.error) {
          $('error').textContent = data.error;
          $('error').classList.remove('hidden');
          return;
        }

        // Save password
        localStorage.setItem('cockpit_pw', password);

        // Show dashboard
        $('login').classList.add('hidden');
        $('dashboard').classList.remove('hidden');

        render(data);
      } catch (e) {
        $('error').textContent = 'Fehler: ' + e.message;
        $('error').classList.remove('hidden');
      }
    }

    function render(data) {
      const a = data.apple?.current;
      if (a) {
        $('kpi-paid').textContent = a.paid;
        $('kpi-trial').textContent = a.trial;
        $('split-monthly').textContent = a.monthlyPaid;
        $('split-yearly').textContent = a.yearlyPaid;
        $('trial-monthly').textContent = a.monthlyTrial;
        $('trial-yearly').textContent = a.yearlyTrial;
      }
      if (data.apple?.mrr) {
        $('kpi-mrr').textContent = '€' + data.apple.mrr.monthlyGross.toFixed(0);
        $('kpi-mrr-net').textContent = '€' + data.apple.mrr.monthlyNet.toFixed(0);
      }
      $('lastUpdate').textContent = 'Daten vom ' + (data.apple?.latestDate || '?');
      $('raw').textContent = JSON.stringify(data, null, 2);

      // Render trend bars
      const trend = data.apple?.trend || [];
      if (trend.length) {
        const maxPaid = Math.max(...trend.map(t => t.paid), 1);
        $('trend').innerHTML = trend.map(t => {
          const h = Math.max((t.paid / maxPaid) * 140, 4);
          return `<div class="flex-1 flex flex-col items-center justify-end">
            <div class="text-xs text-emerald-400 mb-1">${t.paid}</div>
            <div class="w-full bg-emerald-500 rounded-t" style="height:${h}px"></div>
          </div>`;
        }).join('');
        $('trend-labels').innerHTML = trend.map(t => 
          `<div class="flex-1 text-center">${t.date.slice(5)}</div>`
        ).join('');
      }
    }
  </script>
</Layout>
