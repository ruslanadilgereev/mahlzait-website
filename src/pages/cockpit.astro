---
// No layout — standalone private page, not indexed
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Mahlzait Cockpit</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; padding: 20px; }
    .login { max-width: 400px; margin: 100px auto; text-align: center; }
    .login input { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #334155; background: #1e293b; color: #e2e8f0; font-size: 16px; margin: 12px 0; }
    .login button { padding: 12px 32px; border-radius: 8px; border: none; background: #009688; color: white; font-size: 16px; cursor: pointer; }
    .login button:hover { background: #00796b; }
    .login button:disabled { background: #334155; cursor: wait; }
    .loading { text-align: center; padding: 40px; color: #94a3b8; font-size: 18px; }
    .dashboard { display: none; }
    .stats { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
    .stat { background: #1e293b; border-radius: 12px; padding: 16px 24px; min-width: 150px; }
    .stat-value { font-size: 28px; font-weight: 700; color: #009688; }
    .stat-label { font-size: 13px; color: #94a3b8; margin-top: 4px; }
    .controls { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
    .controls input, .controls select { padding: 8px 12px; border-radius: 8px; border: 1px solid #334155; background: #1e293b; color: #e2e8f0; font-size: 14px; }
    .controls input { flex: 1; min-width: 200px; }
    .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid #1e293b; }
    table { border-collapse: collapse; width: 100%; font-size: 13px; }
    th { background: #1e293b; padding: 10px 12px; text-align: left; cursor: pointer; white-space: nowrap; position: sticky; top: 0; user-select: none; }
    th:hover { background: #334155; }
    th .arrow { margin-left: 4px; opacity: 0.5; }
    th.sorted .arrow { opacity: 1; color: #009688; }
    td { padding: 8px 12px; border-top: 1px solid #1e293b; white-space: nowrap; max-width: 200px; overflow: hidden; text-overflow: ellipsis; }
    tr:hover td { background: #1e293b; }
    .segment { padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .segment-power { background: #065f46; color: #6ee7b7; }
    .segment-activated { background: #1e3a5f; color: #7dd3fc; }
    .segment-new { background: #3b2f63; color: #c4b5fd; }
    .segment-at_risk { background: #78350f; color: #fbbf24; }
    .segment-churned { background: #7f1d1d; color: #fca5a5; }
    .segment-other { background: #334155; color: #94a3b8; }
    .count { color: #94a3b8; font-size: 14px; }
    .hidden-cols { font-size: 12px; color: #64748b; margin-bottom: 12px; }
    .hidden-cols span { cursor: pointer; text-decoration: underline; margin-right: 8px; }
    .hidden-cols span:hover { color: #94a3b8; }
  </style>
</head>
<body>

<div class="login" id="login">
  <h1 style="margin-bottom: 8px;">Mahlzait Cockpit</h1>
  <p style="color: #94a3b8; margin-bottom: 20px;">Dashboard Token eingeben</p>
  <input type="password" id="token-input" placeholder="Token..." />
  <br/>
  <button onclick="loadData()">Login</button>
  <p id="login-error" style="color: #ef4444; margin-top: 12px; display: none;"></p>
</div>

<div class="dashboard" id="dashboard">
  <h1 style="margin-bottom: 20px;">Mahlzait Cockpit</h1>
  <div class="stats" id="stats"></div>
  <div class="controls">
    <input type="text" id="search" placeholder="Suche (Email, Land, Segment...)" oninput="renderTable()" />
    <select id="segment-filter" onchange="renderTable()">
      <option value="">Alle Segmente</option>
    </select>
    <select id="sub-filter" onchange="renderTable()">
      <option value="">Alle Status</option>
      <option value="premium">Premium</option>
      <option value="free">Free</option>
    </select>
    <span class="count" id="row-count"></span>
  </div>
  <div class="table-wrap" style="max-height: 75vh; overflow-y: auto;">
    <table id="data-table">
      <thead><tr id="table-head"></tr></thead>
      <tbody id="table-body"></tbody>
    </table>
  </div>
</div>

<script is:inline>
  const API = 'https://europe-west1-mytemple-460913.cloudfunctions.net/mahlzait-dashboard-api';

  // Priority columns shown first
  const PRIORITY_COLS = [
    'email', 'platform', 'user_segment', 'current_subscription_status', 'current_plan_type',
    'total_revenue_eur', 'lifetime_purchases', 'total_meals_logged', 'total_sessions',
    'geo_country', 'gender', 'age', 'primary_goal',
    'first_seen_date', 'last_seen_date', 'days_since_last_active',
    'app_version', 'total_features_used'
  ];

  // Columns to hide by default (too noisy)
  const HIDE_COLS = ['user_pseudo_id', 'user_id', '_refreshed_at', 'device_os_version', 'device_language'];

  let allData = { columns: [], rows: [] };
  let sortCol = 'last_seen_date';
  let sortDir = -1; // -1 = desc
  let visibleCols = [];

  async function loadData() {
    const token = document.getElementById('token-input').value.trim();
    if (!token) return;

    const btn = document.querySelector('.login button');
    btn.disabled = true;
    btn.textContent = 'Laden...';
    document.getElementById('login-error').style.display = 'none';

    try {
      const resp = await fetch(`${API}?token=${encodeURIComponent(token)}`);
      if (resp.status === 401) {
        document.getElementById('login-error').textContent = 'Falscher Token';
        document.getElementById('login-error').style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Login';
        return;
      }
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      allData = await resp.json();

      // Save token
      localStorage.setItem('cockpit_token', token);

      // Order columns: priority first, then rest alphabetically, hide some
      const rest = allData.columns.filter(c => !PRIORITY_COLS.includes(c) && !HIDE_COLS.includes(c));
      rest.sort();
      visibleCols = [...PRIORITY_COLS.filter(c => allData.columns.includes(c)), ...rest];

      // Populate segment filter
      const segments = [...new Set(allData.rows.map(r => r.user_segment).filter(Boolean))].sort();
      const segFilter = document.getElementById('segment-filter');
      segFilter.innerHTML = '<option value="">Alle Segmente</option>' +
        segments.map(s => `<option value="${s}">${s}</option>`).join('');

      // Show dashboard
      document.getElementById('login').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';

      renderStats();
      renderTable();
    } catch (e) {
      document.getElementById('login-error').textContent = 'Fehler: ' + e.message;
      document.getElementById('login-error').style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Login';
    }
  }

  function renderStats() {
    const rows = allData.rows;
    const premium = rows.filter(r => r.current_subscription_status === 'premium').length;
    const paying = rows.filter(r => (r.total_revenue_eur || 0) > 0).length;
    const totalRev = rows.reduce((s, r) => s + (r.total_revenue_eur || 0), 0);
    const avgLtv = paying > 0 ? totalRev / paying : 0;
    const active7d = rows.filter(r => (r.days_since_last_active || 999) <= 7).length;

    document.getElementById('stats').innerHTML = `
      <div class="stat"><div class="stat-value">${rows.length}</div><div class="stat-label">Users</div></div>
      <div class="stat"><div class="stat-value">${premium}</div><div class="stat-label">Premium</div></div>
      <div class="stat"><div class="stat-value">${paying}</div><div class="stat-label">Zahlende</div></div>
      <div class="stat"><div class="stat-value">${totalRev.toFixed(0)}&euro;</div><div class="stat-label">Revenue</div></div>
      <div class="stat"><div class="stat-value">${avgLtv.toFixed(0)}&euro;</div><div class="stat-label">Avg LTV</div></div>
      <div class="stat"><div class="stat-value">${active7d}</div><div class="stat-label">Aktiv (7d)</div></div>
    `;
  }

  function getFilteredRows() {
    const search = document.getElementById('search').value.toLowerCase();
    const segmentF = document.getElementById('segment-filter').value;
    const subF = document.getElementById('sub-filter').value;

    let rows = allData.rows;
    if (search) {
      rows = rows.filter(r =>
        Object.values(r).some(v => v != null && String(v).toLowerCase().includes(search))
      );
    }
    if (segmentF) rows = rows.filter(r => r.user_segment === segmentF);
    if (subF) rows = rows.filter(r => r.current_subscription_status === subF);

    // Sort
    rows.sort((a, b) => {
      let va = a[sortCol], vb = b[sortCol];
      if (va == null) va = '';
      if (vb == null) vb = '';
      if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * sortDir;
      return String(va).localeCompare(String(vb)) * sortDir;
    });

    return rows;
  }

  function renderTable() {
    const rows = getFilteredRows();
    document.getElementById('row-count').textContent = `${rows.length} User`;

    // Header
    document.getElementById('table-head').innerHTML = visibleCols.map(col => {
      const arrow = col === sortCol ? (sortDir === 1 ? '&#9650;' : '&#9660;') : '&#8597;';
      const cls = col === sortCol ? 'sorted' : '';
      const label = col.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
      return `<th class="${cls}" onclick="toggleSort('${col}')">${label} <span class="arrow">${arrow}</span></th>`;
    }).join('');

    // Body
    document.getElementById('table-body').innerHTML = rows.map(row =>
      '<tr>' + visibleCols.map(col => {
        let val = row[col];
        if (val == null || val === '') return '<td>-</td>';
        if (col === 'user_segment') {
          return `<td><span class="segment segment-${val}">${val}</span></td>`;
        }
        if (col === 'total_revenue_eur' && typeof val === 'number') {
          return `<td>${val.toFixed(2)}&euro;</td>`;
        }
        if (typeof val === 'boolean') return `<td>${val ? 'Ja' : 'Nein'}</td>`;
        if (typeof val === 'string' && val.match(/^\d{4}-\d{2}-\d{2}/)) val = val.slice(0, 10);
        return `<td title="${String(val)}">${val}</td>`;
      }).join('') + '</tr>'
    ).join('');
  }

  function toggleSort(col) {
    if (sortCol === col) sortDir *= -1;
    else { sortCol = col; sortDir = -1; }
    renderTable();
  }

  // Auto-login from saved token
  window.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('cockpit_token');
    if (saved) {
      document.getElementById('token-input').value = saved;
      loadData();
    }
  });
</script>

</body>
</html>
