---
import { GO_LINKS, getAppStoreUrl, getPlayStoreUrl, FALLBACK_URL } from "../../data/go-links";

export function getStaticPaths() {
  return Object.entries(GO_LINKS).map(([slug, link]) => ({
    params: { slug },
    props: {
      iosUrl: getAppStoreUrl(slug, link),
      androidUrl: getPlayStoreUrl(link),
    },
  }));
}

const { iosUrl, androidUrl } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mahlzait herunterladen</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #f8faf9;
        color: #1a1a1a;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .container {
        text-align: center;
        padding: 2rem;
        max-width: 400px;
      }
      .logo {
        width: 80px;
        height: 80px;
        border-radius: 18px;
        margin-bottom: 1.5rem;
      }
      h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
      }
      .subtitle {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 2rem;
      }
      .spinner {
        width: 24px;
        height: 24px;
        border: 3px solid #e0e0e0;
        border-top-color: #009688;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 1.5rem;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .buttons {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .btn:active { transform: scale(0.97); }
      .btn-ios {
        background: #000;
        color: #fff;
      }
      .btn-android {
        background: #009688;
        color: #fff;
      }
      .btn svg { width: 22px; height: 22px; fill: currentColor; }
      .redirecting .buttons { opacity: 0.5; }
    </style>
  </head>
  <body>
    <div class="container" id="page">
      <img src="/logo.png" alt="Mahlzait" class="logo" />
      <h1>Mahlzait herunterladen</h1>
      <p class="subtitle" id="status">Du wirst weitergeleitet…</p>
      <div class="spinner" id="spinner"></div>
      <div class="buttons">
        <a href={iosUrl} class="btn btn-ios" id="ios-btn">
          <svg viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"/></svg>
          App Store
        </a>
        <a href={androidUrl} class="btn btn-android" id="android-btn">
          <svg viewBox="0 0 24 24"><path d="M17.6 11.48l1.69-2.92c.1-.17.04-.38-.12-.47-.17-.1-.38-.04-.47.12l-1.71 2.96A9.08 9.08 0 0012 9.96c-1.81 0-3.48.47-4.99 1.21L5.3 8.21c-.1-.17-.31-.22-.47-.12-.17.1-.22.31-.12.47l1.69 2.92C2.77 13.41.34 17.31 0 22h24c-.34-4.69-2.77-8.59-6.4-10.52M7 19c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1m10 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1"/></svg>
          Google Play
        </a>
      </div>
    </div>
    <script define:vars={{ iosUrl, androidUrl }}>
      const ua = navigator.userAgent || "";
      const isIOS = /iPhone|iPad|iPod/i.test(ua);
      const isAndroid = /Android/i.test(ua);

      if (isIOS || isAndroid) {
        document.getElementById("page").classList.add("redirecting");
        window.location.href = isIOS ? iosUrl : androidUrl;
      } else {
        // Desktop: Spinner weg, beide Buttons zeigen
        document.getElementById("spinner").style.display = "none";
        document.getElementById("status").textContent =
          "Wähle deinen Store:";
      }
    </script>
  </body>
</html>
