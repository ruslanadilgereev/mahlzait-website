---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import TeamPage from "@modules/team";

const teamSeo = {
  title: "Team - Mahlzait | Smartes Tracking statt Barcode-Frust",
  description:
    "Das Team hinter Mahlzait. Wir ersetzen nerviges Barcode-Scannen durch intelligente AI. Gründer Ruslan Adilgereev baut das Tool, das er selbst vermisst hat.",
};

const company = {
  name: "Mahlzait",
  mission:
    "Tracking, das nicht rät: multimodale KI mit Live-Web-Recherche und Quellenangaben — statt blinder Schätzung aus dem Sprachmodell-Trainings-Datensatz.",
  founded: "2025",
  location: "Berlin",
  email: "kontakt@mahlzait.de",
  website: "https://www.mahlzait.de",
};

const founder = {
  id: `${company.website}/#person-ruslan`,
  name: "Ruslan Adilgereev",
  role: "Founder & Engineer",
  bio:
    "Ingenieur & Pragmatiker aus Berlin. Hat Mahlzait gebaut, weil andere KI-Tracker bei Restaurant-Gerichten und regionalen Produkten zu oft daneben lagen — sie schätzen aus ihrem LLM-Trainings-Datensatz ohne Web-Zugriff, vergleichbar einem ChatGPT ohne Internet. Mahlzaits Antwort: eine mitdenkende KI mit fünf Eingabe-Formaten (Foto, Video, Barcode, Text, Rezept-Link) und Live-Web-Recherche mit Quellenangaben. Machine Learning + UX, die funktioniert.",
  linkedin: "https://www.linkedin.com/in/ruslanadilgereev",
  image: null,
};

const schema0 = {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": founder.id,
      name: founder.name,
      jobTitle: "Founder & Engineer",
      description:
        "Solo-Founder von Mahlzait, einem multimodalen Kalorienzähler mit mitdenkender KI und Live-Web-Recherche. Berliner Engineer mit Machine-Learning-Hintergrund.",
      knowsAbout: [
        "Calorie Counting",
        "Mobile App Development",
        "Machine Learning",
        "Large Language Models",
        "Nutrition Tracking",
        "Multimodal AI",
        "Food Recognition AI",
      ],
      worksFor: {
        "@type": "Organization",
        "@id": `${company.website}#organization`,
        name: company.name,
      },
      url: `${company.website}/team`,
      sameAs: [founder.linkedin],
      ...(founder.image ? { image: founder.image } : {}),
    };

const schema1 = {
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": `${company.website}#organization`,
      name: company.name,
      email: `mailto:${company.email}`,
      foundingDate: company.founded,
      foundingLocation: { "@type": "Place", name: "Berlin, Germany" },
      founder: { "@id": founder.id },
    };
---

<Layout {...defaultTemplateConfig} seo={teamSeo}>
  <StructuredData config={defaultTemplateConfig} type="page" pageTitle="Team" />

  <!-- Zusätzliche strukturierte Daten: Person + erweiterte Organisation -->
  <script type="application/ld+json" set:html={JSON.stringify(schema0)} />
  <script type="application/ld+json" set:html={JSON.stringify(schema1)} />

  <TeamPage client:load config={defaultTemplateConfig} />
</Layout>


