---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import KalorienFoodPage from "@modules/kalorienFood";
import { articlesMeta } from "@content/wissen";
import { getCalculatorsForFood } from "utils/topicClusters";
const relatedFoodFiles = import.meta.glob("../../data/foods/*.json", { eager: true });

export async function getStaticPaths() {
  const foodFiles = import.meta.glob("../../data/foods/*.json", { eager: true });
  return Object.values(foodFiles).map((mod: any) => {
    const food = mod.default || mod;
    return {
      params: { slug: food.slug },
      props: { food },
    };
  });
}

const { food } = Astro.props;
const allFoodsBySlug = Object.fromEntries(
  Object.values(relatedFoodFiles).map((mod: any) => {
    const entry = mod.default || mod;
    return [entry.slug, entry];
  })
);

const relatedFoodsMeta = (food.related_foods || [])
  .map((slug: string) => allFoodsBySlug[slug])
  .filter(Boolean)
  .map((entry: any) => ({
    slug: entry.slug,
    name: entry.name,
    emoji: entry.emoji,
  }));

const seo = {
  title: food.seo.title,
  description: food.seo.description,
};

// Find related wissen articles by matching food-relevant tags
const foodTagMap: Record<string, string[]> = {
  supermarkt: ["Ernährungsplan", "Makros", "Protein", "Meal Prep", "Kalorienbedarf"],
  gericht: ["Abnehmen", "Kaloriendefizit", "Ernährungsplan", "Kalorien zählen"],
  "fast-food": ["Abnehmen", "Kaloriendefizit", "Heißhunger", "Cheat Day"],
  getraenk: ["Abnehmen", "Intervallfasten", "Alkohol"],
};
const relevantTags = foodTagMap[food.category] || ["Abnehmen", "Ernährungsplan"];
const relatedArticles = articlesMeta
  .filter((a) => a.tags.some((t) => relevantTags.some((rt) => t.toLowerCase().includes(rt.toLowerCase()))))
  .slice(0, 4)
  .map((a) => ({ slug: a.slug, title: a.title, description: a.description, tags: a.tags }));

// Food-spezifische Calculators (z.B. Pizza → pizza-kalorien-rechner)
const foodSpecificCalculators = getCalculatorsForFood(food);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: food.faq.map((item: any) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};

const nutritionSchema = {
  "@context": "https://schema.org",
  "@type": "NutritionInformation",
  name: food.name,
  servingSize: `${food.overview.typical_portion_g}g`,
  calories: `${Math.round(food.overview.calories_per_100g * food.overview.typical_portion_g / 100)} kcal`,
  proteinContent: `${Math.round(food.overview.protein_per_100g * food.overview.typical_portion_g / 100)}g`,
  carbohydrateContent: `${Math.round(food.overview.carbs_per_100g * food.overview.typical_portion_g / 100)}g`,
  fatContent: `${Math.round(food.overview.fat_per_100g * food.overview.typical_portion_g / 100)}g`,
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `${food.name} Kalorien berechnen`,
  description: `Berechne die Kalorien und Nährwerte von ${food.name} mit dem kostenlosen Rechner`,
  totalTime: "PT1M",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Portionsgröße wählen",
      text: `Wähle die gewünschte Portionsgröße für ${food.name} – von klein bis groß oder eine eigene Grammzahl.`,
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Nährwerte ablesen",
      text: `Lies die berechneten Kalorien, Protein, Kohlenhydrate und Fett für deine ${food.name}-Portion ab.`,
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Varianten vergleichen",
      text: `Vergleiche verschiedene ${food.name}-Varianten und finde die kalorienärmste Option.`,
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Mit Mahlzait tracken",
      text: `Tracke ${food.name} direkt in der Mahlzait App per Foto, Barcode oder Suche.`,
    },
  ],
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: `${food.name} Kalorien Rechner`,
  description: `Kostenloser Online-Rechner zur Berechnung der Kalorien und Nährwerte von ${food.name}`,
  applicationCategory: "HealthApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "EUR",
  },
  featureList: [
    `Kalorien und Nährwerte für ${food.name} berechnen`,
    "Portionsgröße anpassen",
    "Varianten vergleichen",
    "Kalorienverbrauch beim Sport berechnen",
    "Tipps zum Kalorien sparen",
  ],
  isBasedOn: [
    {
      "@type": "Dataset",
      name: "Bundeslebensmittelschlüssel (BLS)",
      url: "https://www.blsdb.de",
    },
    {
      "@type": "Dataset",
      name: "Open Food Facts",
      url: "https://world.openfoodfacts.org",
    },
    {
      "@type": "Dataset",
      name: "USDA FoodData Central",
      url: "https://fdc.nal.usda.gov",
    },
  ],
};

const authorPersonSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.mahlzait.de/#person-ruslan",
  name: "Ruslan Adilgereev",
  url: "https://www.mahlzait.de/team",
  jobTitle: "Founder",
  worksFor: {
    "@type": "Organization",
    name: "Mahlzait",
    url: "https://www.mahlzait.de",
  },
  sameAs: [
    "https://www.linkedin.com/in/ruslanadilgereev",
  ],
};
---

<Layout {...defaultTemplateConfig} seo={seo}>
  <StructuredData
    config={defaultTemplateConfig}
    type="page"
    pageTitle={`${food.name} Kalorien Rechner`}
    pageDescription={food.seo.description}
  />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(nutritionSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(authorPersonSchema)} />

  <KalorienFoodPage
    client:visible
    config={defaultTemplateConfig}
    food={food}
    relatedFoodsMeta={relatedFoodsMeta}
    relatedArticles={relatedArticles}
    foodSpecificCalculators={foodSpecificCalculators}
  />
</Layout>
