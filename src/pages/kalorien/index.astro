---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import KalorienIndexPage from "@modules/kalorienIndex";

const foodFiles = import.meta.glob("../../data/foods/*.json", { eager: true });

interface FoodData {
  slug: string;
  name: string;
  emoji: string;
  category: string;
  overview: {
    calories_per_100g: number;
    protein_per_100g: number;
    carbs_per_100g: number;
    fat_per_100g: number;
  };
}

const foods: FoodData[] = Object.values(foodFiles)
  .map((mod: any) => mod.default || mod)
  .sort((a: FoodData, b: FoodData) => a.name.localeCompare(b.name, 'de'));

const seo = {
  title: "Kalorientabelle: Kalorien & Nährwerte von 200+ Lebensmitteln | Mahlzait",
  description: "Wie viele Kalorien hat...? Finde Kalorien, Protein, Kohlenhydrate & Fett von über 200 Lebensmitteln. Vom Döner bis zum Apfel – alle Nährwerte auf einen Blick.",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.mahlzait.de/" },
    { "@type": "ListItem", "position": 2, "name": "Kalorientabelle", "item": "https://www.mahlzait.de/kalorien/" }
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Kalorientabelle – Alle Lebensmittel",
  "numberOfItems": foods.length,
  "itemListElement": foods.slice(0, 50).map((food, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `${food.name} – ${food.overview.calories_per_100g} kcal pro 100g`,
    "url": `https://www.mahlzait.de/kalorien/${food.slug}/`
  }))
};
---

<Layout {seo} templateConfig={defaultTemplateConfig}>
  <StructuredData slot="head" data={breadcrumbSchema} />
  <StructuredData slot="head" data={itemListSchema} />

  <KalorienIndexPage client:load config={defaultTemplateConfig} foods={foods} />
</Layout>
