---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";

const foodFiles = import.meta.glob("../../data/foods/*.json", { eager: true });

interface FoodData {
  slug: string;
  name: string;
  emoji: string;
  category: string;
  overview: {
    calories_per_100g: string;
    protein_per_100g: string;
    carbs_per_100g: string;
    fat_per_100g: string;
  };
}

const foods: FoodData[] = Object.values(foodFiles)
  .map((mod: any) => mod.default || mod)
  .sort((a: FoodData, b: FoodData) => a.name.localeCompare(b.name, 'de'));

const categories: Record<string, { label: string; emoji: string }> = {
  'supermarkt': { label: 'Supermarkt & Grundnahrungsmittel', emoji: '🛒' },
  'gericht': { label: 'Gerichte & Mahlzeiten', emoji: '🍽️' },
  'fast-food': { label: 'Fast Food & Snacks', emoji: '🍔' },
  'getraenk': { label: 'Getränke', emoji: '🥤' },
};

const grouped: Record<string, FoodData[]> = {};
for (const food of foods) {
  const cat = food.category || 'sonstiges';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(food);
}

const seo = {
  title: "Kalorientabelle: Kalorien & Nährwerte von 200+ Lebensmitteln | Mahlzait",
  description: "Wie viele Kalorien hat...? Finde Kalorien, Protein, Kohlenhydrate & Fett von über 200 Lebensmitteln. Vom Döner bis zum Apfel – alle Nährwerte auf einen Blick.",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.mahlzait.de/" },
    { "@type": "ListItem", "position": 2, "name": "Kalorientabelle", "item": "https://www.mahlzait.de/kalorien/" }
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Kalorientabelle – Alle Lebensmittel",
  "numberOfItems": foods.length,
  "itemListElement": foods.slice(0, 50).map((food, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": `${food.name} – ${food.overview.calories_per_100g} kcal pro 100g`,
    "url": `https://www.mahlzait.de/kalorien/${food.slug}/`
  }))
};
---

<Layout {seo} templateConfig={defaultTemplateConfig}>
  <StructuredData slot="head" data={breadcrumbSchema} />
  <StructuredData slot="head" data={itemListSchema} />

  <main class="max-w-5xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1">
        <li><a href="/" class="hover:text-emerald-600">Startseite</a></li>
        <li>/</li>
        <li class="text-gray-800 font-medium">Kalorientabelle</li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        🍎 Kalorientabelle: Kalorien & Nährwerte von {foods.length}+ Lebensmitteln
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">
        Wie viele Kalorien hat ein Döner? Wie viel Protein steckt in Hähnchenbrust? 
        Unsere Kalorientabelle zeigt dir <strong>Kalorien, Protein, Kohlenhydrate und Fett</strong> von 
        über {foods.length} Lebensmitteln – von Fast Food bis Obst, von Fertiggerichten bis Grundnahrungsmitteln.
        Alle Angaben pro 100 g, wissenschaftlich fundiert.
      </p>
    </header>

    <!-- Quick Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="bg-emerald-50 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-emerald-700">{foods.length}+</div>
        <div class="text-sm text-emerald-600">Lebensmittel</div>
      </div>
      <div class="bg-blue-50 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-blue-700">{Object.keys(grouped).length}</div>
        <div class="text-sm text-blue-600">Kategorien</div>
      </div>
      <div class="bg-purple-50 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-purple-700">100%</div>
        <div class="text-sm text-purple-600">Kostenlos</div>
      </div>
      <div class="bg-orange-50 rounded-xl p-4 text-center">
        <div class="text-2xl font-bold text-orange-700">2026</div>
        <div class="text-sm text-orange-600">Aktualisiert</div>
      </div>
    </div>

    <!-- Intro text for SEO -->
    <section class="prose prose-lg max-w-none mb-10">
      <p>
        Du willst <strong>Kalorien zählen</strong> und suchst eine zuverlässige Kalorientabelle? 
        Bei Mahlzait findest du die Nährwerte von über {foods.length} Lebensmitteln – 
        inklusive beliebter Gerichte wie <a href="/kalorien/doener/">Döner</a>, 
        <a href="/kalorien/pizza/">Pizza</a> und <a href="/kalorien/schnitzel/">Schnitzel</a>. 
        Jede Seite enthält detaillierte Angaben zu <strong>Kalorien, Eiweiß, Kohlenhydraten und Fett</strong> 
        pro 100 g sowie typische Portionsgrößen.
      </p>
      <p>
        Noch einfacher geht's mit der <a href="/">Mahlzait App</a>: 
        Fotografiere dein Essen und unsere KI erkennt automatisch die Kalorien. 
        Oder scanne den Barcode – aus einer Datenbank mit über 10 Millionen Produkten.
        <strong>Kostenlos und werbefrei.</strong>
      </p>
    </section>

    <!-- Categories -->
    {Object.entries(categories).map(([catKey, catInfo]) => {
      const items = grouped[catKey];
      if (!items || items.length === 0) return null;
      return (
        <section class="mb-12" id={catKey}>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">
            {catInfo.emoji} {catInfo.label} ({items.length})
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {items.map((food) => (
              <a 
                href={`/kalorien/${food.slug}/`}
                class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-emerald-400 hover:bg-emerald-50 transition-colors group"
              >
                <span class="text-2xl flex-shrink-0">{food.emoji}</span>
                <div class="min-w-0">
                  <div class="font-medium text-gray-900 group-hover:text-emerald-700 truncate">
                    {food.name}
                  </div>
                  <div class="text-sm text-gray-500">
                    {food.overview.calories_per_100g} kcal · {food.overview.protein_per_100g}g Protein · {food.overview.carbs_per_100g}g KH · {food.overview.fat_per_100g}g Fett
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <!-- CTA -->
    <section class="bg-gradient-to-r from-emerald-500 to-teal-600 rounded-2xl p-8 text-center text-white mt-12 mb-10">
      <h2 class="text-2xl font-bold mb-3">Kalorien zählen leicht gemacht</h2>
      <p class="text-emerald-100 mb-6 max-w-xl mx-auto">
        Statt jedes Lebensmittel einzeln nachzuschlagen: Lade die Mahlzait App herunter 
        und tracke dein Essen per Foto, Barcode oder Textsuche. Kostenlos & werbefrei.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://apps.apple.com/de/app/id6747400456" 
           class="inline-flex items-center justify-center bg-white text-emerald-700 font-semibold px-6 py-3 rounded-xl hover:bg-emerald-50 transition-colors"
           target="_blank" rel="noopener">
          🍎 App Store
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.promptit.mytemple" 
           class="inline-flex items-center justify-center bg-white text-emerald-700 font-semibold px-6 py-3 rounded-xl hover:bg-emerald-50 transition-colors"
           target="_blank" rel="noopener">
          🤖 Google Play
        </a>
      </div>
    </section>

    <!-- FAQ for SEO -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Häufige Fragen zur Kalorientabelle</h2>
      <div class="space-y-4">
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Wie genau sind die Kalorienangaben?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Unsere Nährwertangaben basieren auf der Bundeslebensmittelschlüssel-Datenbank (BLS), 
            Open Food Facts und wissenschaftlichen Quellen. Alle Werte beziehen sich auf 100 g 
            des jeweiligen Lebensmittels. Abweichungen je nach Zubereitung und Hersteller sind möglich.
          </p>
        </details>
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Wie viele Kalorien brauche ich am Tag?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Der tägliche Kalorienbedarf hängt von Geschlecht, Alter, Größe, Gewicht und Aktivitätslevel ab. 
            Frauen benötigen durchschnittlich 1.800–2.200 kcal, Männer 2.200–2.800 kcal pro Tag. 
            Berechne deinen individuellen Bedarf mit unserem <a href="/grundumsatz-rechner/" class="text-emerald-600 hover:underline">Grundumsatz-Rechner</a>.
          </p>
        </details>
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Was ist der Unterschied zwischen Kalorien und Kilokalorien?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Im Alltag werden „Kalorien" und „Kilokalorien" (kcal) synonym verwendet. 
            Streng genommen sind 1 kcal = 1.000 Kalorien. Wenn wir sagen „ein Apfel hat 52 Kalorien", 
            meinen wir eigentlich 52 Kilokalorien (kcal).
          </p>
        </details>
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Kann ich mit Kalorien zählen abnehmen?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Ja! Das Prinzip ist einfach: Wer weniger Kalorien zu sich nimmt als er verbraucht, 
            nimmt ab (Kaloriendefizit). Ein Defizit von 500 kcal/Tag führt zu ca. 0,5 kg Gewichtsverlust pro Woche. 
            Die <a href="/" class="text-emerald-600 hover:underline">Mahlzait App</a> hilft dir dabei, 
            dein Kaloriendefizit einfach im Blick zu behalten.
          </p>
        </details>
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Welches Lebensmittel hat die meisten Kalorien?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Reines Fett und Öle haben mit ca. 900 kcal/100g die höchste Kaloriendichte. 
            Bei alltäglichen Lebensmitteln sind Nüsse (600+ kcal), Schokolade (500+ kcal) und Chips (500+ kcal) 
            besonders kalorienreich. In unserer Tabelle findest du die genauen Werte für jedes Lebensmittel.
          </p>
        </details>
        <details class="border border-gray-200 rounded-lg">
          <summary class="p-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
            Wie tracke ich Kalorien am einfachsten?
          </summary>
          <p class="px-4 pb-4 text-gray-600">
            Am schnellsten geht es mit der Mahlzait App: Einfach ein Foto von deinem Essen machen und die 
            KI erkennt automatisch alle Kalorien und Nährwerte. Alternativ kannst du den Barcode scannen 
            oder in der Datenbank mit über 10 Mio. Produkten suchen. 
            <a href="/" class="text-emerald-600 hover:underline">Jetzt kostenlos testen →</a>
          </p>
        </details>
      </div>
    </section>

    <!-- Last updated -->
    <p class="text-sm text-gray-400 text-center">
      Zuletzt aktualisiert: März 2026 · {foods.length} Lebensmittel · Alle Angaben ohne Gewähr
    </p>
  </main>
</Layout>
