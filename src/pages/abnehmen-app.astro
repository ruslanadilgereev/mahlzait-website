---
import Layout from "Layout.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import defaultTemplateConfig from "utils/config";
import AbnehmenAppPage from "@modules/abnehmenApp";
import { abnehmenAppFaq, abnehmenAppHowToSteps, abnehmenAppSeo } from "@modules/abnehmenApp/content";

const seo = abnehmenAppSeo;

const faqSchema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: abnehmenAppFaq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    };

const howToSchema = {
      "@context": "https://schema.org",
      "@type": "HowTo",
      name: "Abnehmen mit App",
      description: seo.description,
      step: abnehmenAppHowToSteps.map((s, i) => ({
        "@type": "HowToStep",
        position: i + 1,
        name: s.name,
        text: s.text,
      })),
    };

const authorPersonSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.mahlzait.de/#person-ruslan",
  name: "Ruslan Adilgereev",
  url: "https://www.mahlzait.de/team",
  jobTitle: "Founder",
  worksFor: {
    "@type": "Organization",
    name: "Mahlzait",
    url: "https://www.mahlzait.de",
  },
  sameAs: [
    "https://www.linkedin.com/in/ruslanadilgereev",
  ],
};

---

<Layout {...defaultTemplateConfig} seo={seo}>
  <StructuredData config={defaultTemplateConfig} type="page" pageTitle="Abnehmen App" />

  <!-- FAQPage Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(authorPersonSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HowTo Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <AbnehmenAppPage client:load config={defaultTemplateConfig} />
</Layout>


